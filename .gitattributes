# Auto detect text files and perform LF normalization
* text=auto

# 明确标记所有UE资源文件为二进制，禁止Git修改它们
*.uasset binary
*.umap binary
*.uexp binary
*.ubulk binary
*.uptnl binary

# 代码和文本文件
*.h text
*.cpp text
*.cs text
*.ini text
*.json text
*.xml text
*.md text
*.bat text
*.sh text
*.gitignore text
*.gitattributes text

# 图片和媒体文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.psd binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.fbx binary
*.obj binary
*.blend binary

# 压缩包和可执行文件
*.zip binary
*.rar binary
*.7z binary
*.exe binary
*.dll binary
*.lib binary
*.so binary
*.dylib binary
